{
  "name": "xlsx-reader",
  "version": "0.2.0",
  "description": "Simple XLSX viewer that parses OpenXML using JSZip and DOMParser",
  "private": true,
  "scripts": {
    "build": "esbuild src/ts/main.ts --bundle --outfile=src/js/app.bundle.js --sourcemap --loader:.json=json",
    "build:prod": "esbuild src/ts/main.ts --bundle --outfile=src/js/app.bundle.js --minify --sourcemap --loader:.json=json",
    "watch": "esbuild src/ts/main.ts --bundle --outfile=src/js/app.bundle.js --sourcemap --watch --loader:.json=json",
    "clean": "rimraf src/js/app.bundle.js src/js/app.bundle.js.map dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "cpx": "^1.5.0",
    "esbuild": "^0.19.0",
    "jsdom": "^28.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
